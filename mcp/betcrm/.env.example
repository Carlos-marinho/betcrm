# Config do MCP server do BetCRM. Copie para `.env` (NÃO commitado) e preencha.
#   cp mcp/betcrm/.env.example mcp/betcrm/.env

# URL da API que o MCP vai dirigir.
#   - dev local:  http://localhost:8000
#   - PRODUÇÃO:   https://SUA-API-DE-PROD   (o MCP roda no seu laptop e fala com
#                 a prod via HTTPS+JWT; nada precisa ser hospedado no servidor)
BETCRM_API_URL=http://localhost:8000

# Credenciais de um usuário com papel admin/member no workspace.
# Use um usuário de serviço dedicado, não a sua conta pessoal.
BETCRM_USERNAME=
BETCRM_PASSWORD=

# Workspace alvo (header X-Workspace-Id). Vazio = workspace default do usuário.
BETCRM_WORKSPACE_ID=

# --- Google Drive (opcional) ---
# Sem isto, o MCP baixa via link público ('qualquer pessoa com o link').
# Para arquivos PRIVADOS, aponte para o JSON de uma service account com acesso
# de leitura ao Drive/pasta (compartilhe a pasta com o email da service account).
# Guarde o JSON em secrets/ (pasta já ignorada pelo git).
GOOGLE_SERVICE_ACCOUNT_FILE=
