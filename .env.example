# ============================================================
# BetCRM — Environment Variables
# ============================================================
# IMPORTANTE: Este é um TEMPLATE. NUNCA commitar o .env real.
# Em produção, gere todos os valores com comandos abaixo:
#
#   DJANGO_SECRET_KEY:   python -c "import secrets; print(secrets.token_urlsafe(50))"
#   senhas (32 chars):   openssl rand -base64 32
#   HMAC secrets (hex):  openssl rand -hex 32
#
# Para preencher em prod:
#   1. ssh deploy@servidor
#   2. cd /home/betcrm/app
#   3. cp .env.example .env
#   4. chmod 600 .env && chown deploy:deploy .env
#   5. nano .env  (preencha com os valores gerados)
# ============================================================

# ---------- ENVIRONMENT ----------
ENVIRONMENT=production  # development | staging | production

# ---------- DJANGO ----------
DJANGO_SETTINGS_MODULE=betcrm.settings.prod
DJANGO_SECRET_KEY=CHANGE_ME_USE_TOKEN_URLSAFE_50
DJANGO_ALLOWED_HOSTS=crm.betnice.net
DJANGO_DEBUG=False
DJANGO_CSRF_TRUSTED_ORIGINS=https://crm.betnice.net
DJANGO_CORS_ALLOWED_ORIGINS=https://crm.betnice.net

# ---------- DATABASE ----------
POSTGRES_DB=betcrm
POSTGRES_USER=betcrm
POSTGRES_PASSWORD=betcrm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://betcrm:CHANGE_ME@postgres:5432/betcrm

# ---------- REDIS ----------
REDIS_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND_32
REDIS_URL=redis://:CHANGE_ME@redis:6379/0

# ---------- CELERY ----------
CELERY_BROKER_URL=redis://:CHANGE_ME@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis:6379/2
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME

# ---------- POSTAL (Email MTA próprio) ----------
POSTAL_ENABLED=true
POSTAL_API_URL=https://postal.yourdomain.com
POSTAL_API_KEY=CHANGE_ME_GENERATED_BY_POSTAL_PANEL
POSTAL_FROM_EMAIL=promo@mg.yourdomain.com
POSTAL_FROM_NAME=Your Brand

# ---------- MAILGUN (fallback) ----------
MAILGUN_ENABLED=true
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_API_KEY=CHANGE_ME
MAILGUN_REGION=us  # us | eu
MAILGUN_FROM_EMAIL=promo@mg.yourdomain.com
MAILGUN_FROM_NAME=Your Brand

# ---------- SMS Webhook (FluxLab inicialmente) ----------
SMS_WEBHOOK_URL=https://api.fluxlab.com/webhook/CHANGE_ME/sms
SMS_WEBHOOK_TOKEN=CHANGE_ME

# ---------- INTEGRAÇÃO PLATAFORMA BET ----------
# HMAC secret usado para validar webhooks de eventos da plataforma de bet
WEBHOOK_HMAC_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
# Secret específica do Meta-System-Webhook (betnice). Se vazio, usa WEBHOOK_HMAC_SECRET.
WEBHOOK_META_SYSTEM_SECRET=

# Lista de IPs permitidos (CIDR ou IP exato), separados por vírgula. Vazio = todos.
WEBHOOK_ALLOWED_IPS=

# ---------- SECURITY ----------
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ---------- MONITORING ----------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- EMAIL DEFAULTS ----------
DEFAULT_FROM_NAME=Your Brand
DEFAULT_SUPPORT_EMAIL=suporte@yourdomain.com
DEFAULT_UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe

# ---------- FREQUENCY CAPS ----------
EMAIL_DAILY_CAP_PER_USER=2
SMS_DAILY_CAP_PER_USER=1
PUSH_DAILY_CAP_PER_USER=3

# ---------- QUIET HOURS (timezone São Paulo) ----------
QUIET_HOURS_START=23  # 23h
QUIET_HOURS_END=8     # 8h

# ---------- TIMEZONE ----------
TIME_ZONE=America/Sao_Paulo
LANGUAGE_CODE=pt-br

# ---------- BRAND ----------
PUBLIC_SITE_URL=https://yourdomain.com
DEPOSIT_URL=https://yourdomain.com/depositar
SUPPORT_URL=https://yourdomain.com/suporte
UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
